{
  "name": "bookfactory-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BookFactory backend — WebSocket control surface for the publishing pipeline.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --loader tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "daemon": "tsx src/daemon/orchestrator.ts",
    "daemon:live": "DAEMON_LIVE=true tsx src/daemon/orchestrator.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.2",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^4.1.6",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.6"
  }
}
